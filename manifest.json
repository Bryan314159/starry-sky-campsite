{
  "manifest_version": 3,
  "name": "星空营地",
  "version": "0.1.0",
  "description": "将书签变成从营地走向星空的沉浸式旅程",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": ["bookmarks", "search"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
